# 老设备 LLM 服务启动脚本
# 以管理员身份运行 PowerShell 后执行（首次运行需要添加防火墙规则）

$ModelPath = "$env:TEMP\qwen2.5-0.5b-q4_k_m.gguf"
$ServerExe = "$env:TEMP\llama-cpp\llama-server.exe"
$Port = 11434

# 检查模型文件
if (-not (Test-Path $ModelPath)) {
    Write-Error "模型文件不存在: $ModelPath"
    exit 1
}

# 检查 server 可执行文件
if (-not (Test-Path $ServerExe)) {
    Write-Error "Server 可执行文件不存在: $ServerExe"
    exit 1
}

# 检查是否已有 server 在运行
$existing = Get-Process -Name "llama-server" -ErrorAction SilentlyContinue
if ($existing) {
    Write-Host "llama-server 已经在运行 (PID: $($existing.Id))" -ForegroundColor Green
} else {
    Write-Host "正在启动 llama-server..." -ForegroundColor Cyan
    Start-Process -FilePath $ServerExe -ArgumentList "-m `"$ModelPath`" --host 0.0.0.0 --port $Port" -WindowStyle Hidden
    Start-Sleep -Seconds 5
    Write-Host "Server 已启动" -ForegroundColor Green
}

# 检查端口
$listener = netstat -an | Select-String "0.0.0.0:$Port"
if ($listener) {
    Write-Host "  [OK] 正在监听 0.0.0.0:$Port" -ForegroundColor Green
} else {
    Write-Warning "  [!] 未检测到端口监听，请检查日志"
}

# 防火墙规则（首次运行需要管理员权限）
$ruleName = "LLM-Server-11434"
$existingRule = Get-NetFirewallRule -DisplayName $ruleName -ErrorAction SilentlyContinue
if (-not $existingRule) {
    try {
        New-NetFirewallRule -DisplayName $ruleName -Direction Inbound -Protocol TCP -LocalPort $Port -Action Allow -Profile Any | Out-Null
        Write-Host "  [OK] 防火墙规则已添加" -ForegroundColor Green
    } catch {
        Write-Warning "  [!] 添加防火墙规则失败（请以管理员身份运行）"
    }
} else {
    Write-Host "  [OK] 防火墙规则已存在" -ForegroundColor Green
}

# 显示连接信息
$ip = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -notmatch "^127\." -and $_.IPAddress -notmatch "^169\.254" } | Select-Object -First 1).IPAddress
Write-Host ""
Write-Host "=== 服务信息 ===" -ForegroundColor Cyan
Write-Host "  模型: Qwen2.5-0.5B-Instruct (Q4_K_M)"
Write-Host "  本机 IP: $ip"
Write-Host "  API 端点: http://${ip}:$Port/v1/chat/completions"
Write-Host "  模型列表: http://${ip}:$Port/v1/models"
Write-Host "  健康检查: http://${ip}:$Port/health"
Write-Host ""
Write-Host "MacBook 连接方式:" -ForegroundColor Yellow
Write-Host "  export OPENAI_API_KEY='dummy'"
Write-Host "  export OPENAI_BASE_URL='http://${ip}:$Port/v1'"
